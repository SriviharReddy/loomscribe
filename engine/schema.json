  {
    "id": "internal_mono",
    "label": "Internal Monologue",
    "type": "toggle",
    "default": true,
    "slot": "system"
  },
  {
    "id": "prose_style",
    "label": "Prose Style",
    "type": "select",
    "options": [
      { "value": "grounded", "label": "Grounded" },
      { "value": "intimate", "label": "Intimate" },
      { "value": "pulp",     "label": "Pulp" }
