    "slot": "system"
  },
  {
    "id": "pov",
    "label": "Point of View",
    "type": "select",
    "options": [
      { "value": "third",  "label": "Close Third" },
      { "value": "first",  "label": "Deep First" },
      { "value": "author", "label": "Omniscient" }
    ],
    "default": "third",
    "slot": "system"
  },
  {
    "id": "explicit",
    "label": "Explicit Content",
    "type": "toggle",
